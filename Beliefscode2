        "final-instructions": {
            "kind": "exp-lookit-instructions",
            "blocks": [
                {
                    "text": "Again, the study will take about 20 minutes to complete. After that, you will be able to select a level of privacy for your data."
                },
                {
                    "title": "Study overview",
                    "listblocks": [
                        {
                            "text": "Your child will hear stories about children doing activities like making a sandwich or buttoning a sweater, and we will ask your child whether they think the parent in the story helped the child do the activity."
                        },
                        {
                            "text": "Your child will click on the answer they think is right, and we will ask them to say why they chose that answer."
                        },
                        {
                            "text": "If your child does not answer out loud, you can prompt them by asking why they chose that answer, but please do not suggest an answer or tell them they are right or wrong. We just want to know what your child thinks!"
                        }
                    ]
