        "study-intro": {
            "kind": "exp-lookit-text",
            "blocks": [
                {
                    "emph": true,
                    "text": "Important: your child does not need to be with you until the videos begin. First, let's go over what will happen!",
                    "title": "Overview of 'What's going on at Sunny School?'"
                },
                {
                    "text": "From start to finish, today's activity will take about 15 minutes. First, your child will hear about a school called Sunny School. We'll learn about something that happened at Sunny School! Then, your child will answer some questions about the characters in the story and what happened."
                },
                {
                    "text": "There are no right or wrong answers to the questions we’re asking – we just want to know what your child thinks, so we kindly ask that you let your child respond freely to the questions. For the duration of the study, please sit behind your child or out of your child's eyesight to avoid influencing their answers. However, if your child needs help clicking their answer choices, please help them do so."
                }
            ],
            "showPreviousButton": false
        },
        "video-config": {
            "kind": "exp-video-config",
            "troubleshootingIntro": "If you're having any trouble getting your webcam set up, please feel free to call the Early Learning and Cognition Lab at (650)-814-4126 and we'd be glad to help you out!"
        },
         "video-consent": {
            "gdpr": false,
            "kind": "exp-lookit-video-consent",
            "PIName": "Julia Leonard",
            "datause": "We are primarily interested in what your child thinks about what happened at Sunny School. A research assistant will watch your video to verify which options your child chose.",
            "payment": "You will be emailed a $5 Amazon gift card within one week of participating in this study. To be eligible for the gift card your child must be in the age range for this study, you need to submit a valid consent statement, and we need to see that there is a child with you. We will send a gift card even if you do not finish the whole study or we are not able to use your child's data! There are no other direct benefits to you or your child from participating, but we hope you will enjoy the experience.",
            "purpose": "In this study, we are interested in how children understand rules that disparately impact particular social groups (e.g., race, gender). We are curious how different factors might impact children's perceptions of these rules!",
            "template": "consent_005",
            "PIContact": "Julia Leonard at yalelearninglab@gmail.com",
            "procedures": "In the study, your child will hear about a school called Sunny School. They will learn about something that happened at Sunny School and answer a series of questions by clicking on the screen. \r There are no right or wrong answers in this game. We are just curious what your child thinks! We will ask you (the parent) to avoid discussing the game with your child until the end. You will be given a chance to preview what your child will see before before the study begins. There are no anticipated risks associated with participating.",
            "institution": "Yale University",
            "research_rights_statement": "You are not waiving any legal claims, rights or remedies because of your participation in this research study.  If you feel you have been treated unfairly, or you have questions regarding your rights as a research subject, you may contact the Chairman of the Committee on the Use of Humans as Experimental Subjects, M.I.T., Room E25-143B, 77 Massachusetts Ave, Cambridge, MA 02139, phone 1-617-253 6787."
        },
