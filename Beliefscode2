        "final-instructions": {
            "kind": "exp-lookit-instructions",
            "blocks": [
                {
                    "text": "Again, the study will take about 10 minutes to complete. After that, you will be able to select a level of privacy for your data."
                },
                {
                    "title": "Study overview",
                    "listblocks": [
                        {
                            "text": "Your child will hear a story about a school called Sunny School."
                        },
                        {
                            "text": "Then your child will answer some questions about the story and what happened in it."
                        }
                    ]
                },
                {
                    "title": "Pausing and stopping",
                    "listblocks": [
                        {
                            "text": "If your child gets distracted, or you need to attend to something else for a moment, you can pause the study by pressing the space bar."
                        },
                        {
                            "text": "If you need to end the study early, try closing the window or tab and you should see an 'exit' option pop up. You’ll be prompted to note any technical problems you might be experiencing and to select a privacy level for your videos."
                        }
                    ]
                },
                {
                    "text": "Please turn the volume up so it's easy to hear but still comfortable.",
                    "title": "Test your audio",
                    "mediaBlock": {
                        "text": "You should hear 'Ready to go!'",
                        "isVideo": false,
                        "sources": [
                            {
                                "src": "https://s3.amazonaws.com/lookitcontents/exp-physics-final/audio/ready.mp3",
                                "type": "audio/mp3"
                            },
                            {
                                "src": "https://s3.amazonaws.com/lookitcontents/exp-physics-final/audio/ready.ogg",
                                "type": "audio/ogg"
                            }
                        ],
                        "mustPlay": true,
                        "warningText": "Please try playing the sample audio."
                    }
                }
            ],
            "nextButtonText": "Let's get in position!"
        },
        "webcam-display-break": {
            "kind": "exp-lookit-webcam-display",
            "blocks": [
                {
                    "title": "We're ready to get started!",
                    "listblocks": [
                        {
                            "text": "Please make sure that your child is visible in the webcam."
                        },
                        {
                            "text": "You can say hi to the camera!"
                        }
                    ]
                },
                {
                    "title": "During the videos",
                    "listblocks": [
                        {
                            "text": "Please sit behind your child and allow your child to answer the questions on their own. Please don’t correct your child if you disagree, or tell them they’re right if you agree. We’re just interested in what they think! If your child isn’t sure or doesn’t want to answer a question, you can encourage them to make their best guess."
                        },
                        {
                            "text": "However, if your child is having any issues clicking the images, you may help them click."
                        }
                    ]
                }
            ],
            "nextButtonText": "Let's get started!",
